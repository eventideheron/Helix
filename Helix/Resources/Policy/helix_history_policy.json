{
  "policy_version": "1.3",
  "created": "2026-03-10",
  "updated": "2026-04-24",
  "status": "active",
  "description": "Longitudinal pattern detection, Today In History, prior-year anchored seasonal lookback, trend detection, milestones.",
  "changelog": [
    {
      "version": "1.0",
      "date": "2026-03-10",
      "notes": "Initial release. Most features require 90 days minimum. Seasonal detection requires 365 days and 2 years for confirmation."
    },
    {
      "version": "1.1",
      "date": "2026-03-11",
      "notes": "Cleaned PDF extraction artifacts. Simplified trigger structures for Swift Decodable compatibility."
    },
    {
      "version": "1.2",
      "date": "2026-04-05",
      "notes": "Prior-year anchored seasonal window (t−365), distance decay weighting, baseline_relationship + seasonal_outputs governance, provisional vs confirmed classification; replaces rolling_year_comparison."
    },
    {
      "version": "1.3",
      "date": "2026-04-24",
      "notes": "History maturity learning copy: distinguish Helix record depth from Apple Health calibration; milestone thresholds unchanged in Swift."
    }
  ],
  "baseline_relationship": {
    "scoring_baseline_source": "helix_policy.baseline",
    "scoring_baseline_window_days": 90,
    "scoring_baseline_method": "exponentially_weighted_moving_average",
    "seasonal_layer_affects_scoring": false,
    "seasonal_layer_affects_explanation": true,
    "seasonal_layer_affects_user_warnings": true,
    "note": "Seasonal logic is a secondary interpretation layer only. It never replaces or mutates the 90-day EWMA baseline used for signal normalization and daily scoring."
  },
  "activation_requirements": {
    "minimum_days_for_basic_history": 90,
    "minimum_days_for_seasonal_detection": 365,
    "minimum_years_for_seasonal_confirmation": 2
  },
  "today_in_history": {
    "enabled": true,
    "triggers": {
      "personal_record_percentile": 95,
      "personal_record_lookback_days": 365,
      "strand_record_percentile": 95,
      "strand_record_lookback_days": 180,
      "streak_milestone_days": [7, 14, 21, 30, 60, 90],
      "baseline_improvement_threshold_percent": 0.10,
      "baseline_improvement_comparison_days": 90,
      "historical_match_similarity_threshold": 0.85,
      "historical_match_minimum_helix_index": 80,
      "historical_match_minimum_duration_days": 5
    }
  },
  "seasonal_detection": {
    "enabled": true,
    "detection_method": "prior_year_anchored_window",
    "comparison_anchor_days_ago": 365,
    "comparison_window_days_before_anchor": 30,
    "comparison_window_days_after_anchor": 30,
    "minimum_days_in_window": 14,
    "window_weighting_method": "distance_decay_from_anchor",
    "distance_decay_curve": "linear",
    "exact_anchor_day_weight": 1.0,
    "edge_of_window_weight": 0.35,
    "use_smoothed_current_values": true,
    "current_smoothing_window_days": 14,
    "comparison_mode": "same_season_last_year",
    "ignore_fixed_month_buckets": true,
    "pattern_confirmation": {
      "minimum_years": 2,
      "minimum_correlation": 0.65,
      "minimum_repeat_observations": 2
    },
    "classification": {
      "provisional_after_first_year": true,
      "confirmed_after_second_year": true
    },
    "warning_lead_days": 14,
    "sleep_decline_threshold_points": 8,
    "recovery_suppression_threshold_points": 10,
    "training_disruption_variance_threshold": 0.30
  },
  "seasonal_outputs": {
    "allow_explanatory_context": true,
    "allow_supporting_insight_cards": true,
    "allow_warning_messages": true,
    "allow_baseline_replacement": false,
    "allow_direct_score_modification": false,
    "message_modes": {
      "provisional": "This may reflect a pattern Helix saw around this time last year.",
      "confirmed": "This resembles a pattern Helix has seen across multiple years at this time of year."
    }
  },
  "comparison_windows": {
    "short_term_days": 30,
    "medium_term_days": 90,
    "long_term_days": 365,
    "all_time": true,
    "percentile_bands": {
      "exceptional": 95,
      "strong": 75,
      "normal": 50,
      "below_normal": 25,
      "poor": 10
    }
  },
  "trend_detection": {
    "short_trend_days": 7,
    "medium_trend_days": 30,
    "thresholds": {
      "meaningful_change_percent": 0.05,
      "significant_change_percent": 0.10,
      "strong_change_percent": 0.20
    },
    "smoothing": {
      "method": "3_day_weighted_moving_average",
      "display_raw_on_tap": true,
      "trend_arrow_up_threshold": 0.05,
      "trend_arrow_down_threshold": 0.05
    }
  },
  "milestones": {
    "enabled": true,
    "consistency_milestone_days": [30, 60, 90, 180, 365],
    "baseline_maturity_stages": {
      "learning": {
        "day_range": [0, 13],
        "message": "Helix has {days_remaining} days of its own records. Scores are calibrated to your Apple Health history."
      },
      "developing": {
        "day_range": [14, 89],
        "message": "Baseline developing — scores become more accurate as your history grows."
      },
      "established": {
        "day_range": [90, 364],
        "message": "Baseline established. Scores are well-calibrated to your physiology."
      },
      "mature": {
        "day_range": [365, 9999],
        "message": "Mature baseline — Helix now compares this period to the same seasonal window from the prior year."
      }
    }
  }
}
