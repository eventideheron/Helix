    {
      "version": "1.1",
      "date": "2026-03-10",
      "notes": "CRITICAL FIX: Normalized decay_rates keys to match SignalIdentifier rawValues used in Swift engine (resting_hr, sleep_duration, respiratory_rate, wrist_temperature). Added missing validation_ranges for spo2_rolling_average and bedtime_wake_variance_minutes. These mismatches caused silent fallback to 0.94 decay rate for sleep_duration, respiratory_rate, and wrist_temperature baselines."
    },
    {
      "version": "1.1",
      "date": "2026-04-01",
      "notes": "Load `strand_load.hr_elevation` coefficients activated in app code (cost_per_bpm_above_baseline 7.0, maximum_penalty 30.0); scoring uses workout HR vs resting HR EWMA baseline. No coefficient changes in this JSON."
    }
